# 왼쪽에 줄 번호를 표시
set linenumbers
#탭 문자를 4칸으로 인식
set tabsize 4
#탭을 입력하면 실제 탭 문자가 아니라 공백(space)으로 변환
set tabstospaces
#새 줄을 시작할 때 이전 줄의 들여쓰기를 자동
set autoindent
# 마우스로 텍스트 선택이나 위치 이동이 가능
# set mouse
# 활성화하면 스크롤이 부드럽게 움직
# set smooth
# 긴 줄이 화면 너비를 넘어가면 자동으로 줄바꿈
set softwrap
#상태 표시줄에 항상 커서 위치(줄, 열 번호)
set constantshow
#화면 하단의 상태 표시줄을 간소화된 형태
set minibar
#파일 내에서 현재 위치를 표시하는 작은 스크롤 막대를 화면 오른쪽에 표시
set indicator
#검색/치환 기록을 저장해서 다음 실행 시에도 불러올 수 있
set historylog
#시스템에 설치된 문법 강조 파일들을 모두 호출
# 예를 들어 python.nanorc, c.nanorc 같은 파일이 있으면 해당 언어 문법 하이라이트가 적용됩니다.
include /usr/share/nano/*.nanorc
